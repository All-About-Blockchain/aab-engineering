# aab.engineering Environment Variables

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# API Keys
API_KEY=your-api-key-here
CRON_KEY=trident_cron_key_2026

# RPC Endpoints (optional - uses defaults if not set)
ETHEREUM_RPC=https://eth.llamarpc.com
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC=https://mainnet.optimism.io
BASE_RPC=https://mainnet.base.org
POLYGON_RPC=https://polygon-rpc.com
SOLANA_RPC=https://api.mainnet-beta.solana.com
OSMOSIS_RPC=https://osmosis-rpc.polkachu.com
INJECTIVE_RPC=https://injective-rpc.polkachu.com
COSMOS_RPC=https://cosmos-rpc.polkachu.com
AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc

# External APIs
JUPITER_API=https://api.jup.ag
DEFILLAMA_API=https://yields.llama.fi

# Database (future)
DATABASE_URL=postgresql://user:password@localhost:5432/aab_engineering

# Auth
JWT_SECRET=your-jwt-secret-here
